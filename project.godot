; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Forest Dungeon"
run/main_scene="uid://df7a5ffsl7ce"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Assets/2D/UI/altar_icon_good_scale.png"

[autoload]

Basics="*res://Scripts/Autoload/basics.gd"
DebugFeatures="*res://Scripts/Autoload/debug_features.gd"
Replication="*res://Scripts/Autoload/replication.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/borderless=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/energy_saving/keep_screen_on=false
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://GameServer/": "red",
"res://Resources/": "green",
"res://Scenes/": "orange",
"res://Scripts/": "purple"
}

[filesystem]

import/blender/enabled=false

